# LLM/API provider keys. Leave blank unless you intend to run new model calls.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Search provider key. Required only for fetching new live SerpAPI results.
SERPAPI_KEY=
SERPAPI_API_KEY=

# Mock search API config.
MOCK_API_HOST=localhost
MOCK_API_PORT=8001
MOCK_SEARCH_API_URL=http://localhost:8001

# Experiment config.
GLOBAL_SEED=42
RESULTS_DIR=results

# Judge models are configured in config/models.yaml.
